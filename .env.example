# Copy to .env and adjust. docker-compose substitutes these values.

POSTGRES_PASSWORD=change-this-db-password
SECRET_KEY=use-a-long-random-string

# Hostname clients use to reach code-server (no port). After signup, redirect is
# {VSCODE_PUBLIC_SCHEME}://{VSCODE_PUBLIC_HOST}:{port}/
VSCODE_PUBLIC_HOST=localhost
VSCODE_PUBLIC_SCHEME=http

# Pool of host ports mapped to code-server containers (web container publishes these).
VSCODE_PORT_MIN=9000
VSCODE_PORT_MAX=9100

# Public HTTPS clone URL (SSH URLs require keys inside the code-server image).
EV_REPO_GIT_URL=https://github.com/DmitrySlesarev/az1m0v.git

# Set 0 to skip Docker API (e.g. local Flask dev without spawning IDEs).
ENABLE_VSCODE_SPAWN=1

# Landing page demo figures
CROWDFUNDING_GOAL_USD=250000
CROWDFUNDING_RAISED_USD=42000
